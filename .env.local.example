# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and will never be committed.

# AWS Region
REACT_APP_AWS_REGION=us-east-2

# Cognito User Pool
REACT_APP_COGNITO_USER_POOL_ID=us-east-2_XXXXXXXXX
REACT_APP_COGNITO_CLIENT_ID=your-cognito-app-client-id
REACT_APP_COGNITO_DOMAIN=your-domain.auth.us-east-2.amazoncognito.com

# CloudFront URL (used for production redirect URIs)
REACT_APP_CLOUDFRONT_URL=https://your-distribution-id.cloudfront.net
